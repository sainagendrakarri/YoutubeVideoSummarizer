{
  "manifest_version": 3,
  "name": "YouTube Video Summariser",
  "description": "Generate concise summaries of YouTube videos using transcripts and Hugging Face Transformers.",
  "version": "1.0.0",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://www.youtube.com/*",
    "https://youtu.be/*"
  ],

  "action": {
    "default_title": "Summarise Video",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon.png",
      "32": "images/icon.png",
      "48": "images/icon.png",
      "128": "images/icon.png"
    }
  },

  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  }
}
